{
  "name": "@omron-fins/native",
  "version": "0.6.0",
  "description": "Omron FINS protocol - Native Node.js/Bun bindings powered by Rust",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "omron-fins": "./dist/omron-fins.node"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/deviagomendes/omron-fins-rs"
  },
  "license": "MIT",
  "keywords": [
    "omron",
    "fins",
    "plc",
    "industrial",
    "automation",
    "native",
    "rust",
    "napi",
    "linux"
  ],
  "author": "Iago Aquino Mendes",
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "dist/*.node",
    "LINUX_GUIDE.md"
  ],
  "napi": {
    "binaryName": "omron-fins",
    "targets": [
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "engines": {
    "node": ">= 18",
    "bun": ">= 1.0"
  },
  "os": [
    "linux",
    "darwin",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "scripts": {
    "build": "napi build --platform --features napi --release dist",
    "build:debug": "napi build --platform --features napi dist",
    "build:linux": "cargo build --release --features napi --target x86_64-unknown-linux-gnu && napi build --platform --features napi --release dist",
    "prepublishOnly": "napi prepublish -t npm dist"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2"
  }
}
